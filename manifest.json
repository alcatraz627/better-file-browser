{
  "manifest_version": 3,
  "name": "Better File Browser",
  "version": "2.7.0",
  "description": "Transforms Chrome's plain directory listings into a rich, modern file explorer with file previews and local-model AI",
  "permissions": ["storage", "nativeMessaging", "clipboardWrite"],
  "background": { "service_worker": "background.js" },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["file://*/*"],
      "js": ["loader.js"],
      "run_at": "document_start",
      "all_frames": false
    },
    {
      "matches": ["file://*/*"],
      "js": ["content.js"],
      "run_at": "document_end",
      "all_frames": false
    }
  ]
}
